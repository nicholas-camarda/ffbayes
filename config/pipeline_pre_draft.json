{
  "steps": [
    {
      "name": "data_collection",
      "script": "ffbayes.data_pipeline.collect_data",
      "description": "Collect NFL fantasy football data",
      "timeout": 300,
      "retry_count": 3,
      "dependencies": [],
      "critical": true,
      "parallel_group": "data_processing"
    },
    {
      "name": "data_validation",
      "script": "ffbayes.data_pipeline.validate_data",
      "description": "Validate collected data quality",
      "timeout": 120,
      "retry_count": 2,
      "dependencies": [
        "data_collection"
      ],
      "critical": true,
      "parallel_group": "data_processing"
    },
    {
      "name": "data_preprocessing",
      "script": "ffbayes.data_pipeline.preprocess_analysis_data",
      "description": "Preprocess data for analysis",
      "timeout": 180,
      "retry_count": 2,
      "dependencies": [
        "data_validation"
      ],
      "critical": true,
      "parallel_group": "data_processing"
    },
    {
      "name": "vor_draft_strategy",
      "script": "ffbayes.draft_strategy.traditional_vor_draft",
      "description": "Generate traditional VOR-based draft strategy FIRST to create rankings",
      "timeout": 300,
      "retry_count": 2,
      "dependencies": [
        "data_preprocessing"
      ],
      "critical": true,
      "parallel_group": "strategy"
    },
    {
      "name": "create_unified_dataset",
      "script": "ffbayes.data_pipeline.create_unified_dataset",
      "description": "Create unified dataset with VOR rankings for all models",
      "timeout": 120,
      "retry_count": 2,
      "dependencies": [
        "vor_draft_strategy"
      ],
      "critical": true,
      "parallel_group": "data_processing"
    },
    {
      "name": "hybrid_mc_analysis",
      "script": "ffbayes.analysis.hybrid_mc_bayesian",
      "description": "Run Hybrid Monte Carlo + Bayesian analysis with uncertainty layers",
      "timeout": 900,
      "retry_count": 2,
      "dependencies": [
        "create_unified_dataset"
      ],
      "critical": true,
      "parallel_group": "modeling"
    },
    {
      "name": "bayesian_draft_strategy",
      "script": "ffbayes.draft_strategy.bayesian_draft_strategy",
      "args": "--draft-position 10 --league-size 10 --risk-tolerance medium",
      "description": "Generate optimal draft strategies using Bayesian predictions",
      "timeout": 300,
      "retry_count": 2,
      "dependencies": [
        "hybrid_mc_analysis"
      ],
      "critical": true,
      "parallel_group": "strategy"
    },
    {
      "name": "hybrid_draft_strategy",
      "script": "ffbayes.draft_strategy.hybrid_draft_strategy",
      "args": "--draft-position 10 --league-size 10 --risk-tolerance medium",
      "description": "Generate hybrid VOR + Bayesian draft strategy with Excel output",
      "timeout": 300,
      "retry_count": 2,
      "dependencies": [
        "hybrid_mc_analysis"
      ],
      "critical": true,
      "parallel_group": "strategy"
    },
    {
      "name": "draft_strategy_comparison",
      "script": "ffbayes.analysis.draft_strategy_comparison",
      "description": "Compare VOR and Bayesian draft strategies with analysis and visualizations",
      "timeout": 300,
      "retry_count": 2,
      "dependencies": [
        "vor_draft_strategy",
        "bayesian_draft_strategy"
      ],
      "critical": false,
      "parallel_group": "analysis"
    },
    {
      "name": "pre_draft_visualizations",
      "script": "ffbayes.visualization.create_pre_draft_visualizations",
      "description": "Generate comprehensive pre-draft visualizations for draft strategy",
      "timeout": 180,
      "retry_count": 2,
      "dependencies": [
        "draft_strategy_comparison"
      ],
      "critical": false,
      "parallel_group": "analysis"
    }
  ]
}
