{
  "steps": [
    {
      "name": "data_collection",
      "script": "ffbayes.data_pipeline.collect_data",
      "description": "Collect NFL fantasy football data",
      "args": "--allow-stale-season",
      "env": {
        "FFBAYES_PROCESS_DATASET_PROGRESS": "summary"
      },
      "timeout": 300,
      "retry_count": 3,
      "dependencies": [],
      "critical": true,
      "parallel_group": "data_processing"
    },
    {
      "name": "data_validation",
      "script": "ffbayes.data_pipeline.validate_data",
      "description": "Validate collected data quality",
      "env": {
        "FFBAYES_ALLOW_STALE_SEASON": "true"
      },
      "timeout": 120,
      "retry_count": 2,
      "dependencies": [
        "data_collection"
      ],
      "critical": true,
      "parallel_group": "data_processing"
    },
    {
      "name": "data_preprocessing",
      "script": "ffbayes.data_pipeline.preprocess_analysis_data",
      "description": "Preprocess data for analysis",
      "env": {
        "FFBAYES_ALLOW_STALE_SEASON": "true"
      },
      "timeout": 180,
      "retry_count": 2,
      "dependencies": [
        "data_validation"
      ],
      "critical": true,
      "parallel_group": "data_processing"
    },
    {
      "name": "vor_draft_strategy",
      "script": "ffbayes.draft_strategy.traditional_vor_draft",
      "description": "Generate traditional VOR-based draft strategy FIRST to create rankings",
      "timeout": 300,
      "retry_count": 2,
      "dependencies": [
        "data_preprocessing"
      ],
      "critical": true,
      "parallel_group": "strategy"
    },
    {
      "name": "create_unified_dataset",
      "script": "ffbayes.data_pipeline.create_unified_dataset",
      "description": "Create unified dataset with VOR rankings for all models",
      "env": {
        "FFBAYES_ALLOW_STALE_SEASON": "true"
      },
      "timeout": 120,
      "retry_count": 2,
      "dependencies": [
        "vor_draft_strategy"
      ],
      "critical": true,
      "parallel_group": "data_processing"
    },
    {
      "name": "hybrid_mc_analysis",
      "script": "ffbayes.analysis.hybrid_mc_bayesian",
      "description": "Run Hybrid Monte Carlo + Bayesian analysis with uncertainty layers",
      "timeout": 900,
      "retry_count": 2,
      "dependencies": [
        "create_unified_dataset"
      ],
      "critical": true,
      "parallel_group": "modeling"
    },
    {
      "name": "draft_decision_strategy",
      "script": "ffbayes.draft_strategy.draft_decision_strategy",
      "args": "--draft-position 10 --league-size 10 --risk-tolerance medium",
      "description": "Generate the canonical draft decision board and dashboard",
      "timeout": 300,
      "retry_count": 2,
      "dependencies": [
        "hybrid_mc_analysis"
      ],
      "critical": true,
      "parallel_group": "strategy"
    },
    {
      "name": "team_aggregation",
      "script": "ffbayes.analysis.bayesian_team_aggregation",
      "description": "Aggregate individual predictions to team totals (POST-DRAFT ONLY)",
      "timeout": 300,
      "retry_count": 2,
      "dependencies": [
        "hybrid_mc_analysis"
      ],
      "critical": false,
      "parallel_group": "modeling"
    },
    {
      "name": "monte_carlo_validation",
      "script": "ffbayes.analysis.montecarlo_historical_ff",
      "args": "",
      "description": "Validate drafted teams using Monte Carlo simulation (POST-DRAFT ONLY)",
      "timeout": 600,
      "retry_count": 2,
      "dependencies": [
        "draft_decision_strategy",
        "create_unified_dataset"
      ],
      "critical": false,
      "parallel_group": "validation"
    },
    {
      "name": "post_draft_visualizations",
      "script": "ffbayes.visualization.create_post_draft_visualizations",
      "description": "Generate comprehensive post-draft visualizations for team analysis",
      "timeout": 180,
      "retry_count": 2,
      "dependencies": [
        "monte_carlo_validation",
        "team_aggregation"
      ],
      "critical": false,
      "parallel_group": "analysis"
    }
  ]
}
